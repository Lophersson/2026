<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ─── CSS VARIABLES ─── */
:root {
  --bg: #0d1117;
  --bg2: #161b24;
  --bg3: #1e2635;
  --surface: #232c3d;
  --border: #2d3a50;
  --accent: #c9a84c;
  --accent2: #e8c96e;
  --accent-soft: rgba(201,168,76,0.12);
  --text: #e8edf5;
  --text2: #a8b4c8;
  --text3: #6b7a94;
  --name-color: #f0e6c8;
  --tag-bg: rgba(201,168,76,0.15);
  --tag-border: rgba(201,168,76,0.35);
  --bar-bg: #2d3a50;
  --shadow: 0 4px 24px rgba(0,0,0,0.45);
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.3);
  --radius: 12px;
  --radius-sm: 6px;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Outfit', sans-serif;
}
[data-theme="light"] {
  --bg: #f5f0e8;
  --bg2: #faf7f2;
  --bg3: #ffffff;
  --surface: #ffffff;
  --border: #ddd4c0;
  --accent: #8b6914;
  --accent2: #a07820;
  --accent-soft: rgba(139,105,20,0.08);
  --text: #1a1a2e;
  --text2: #3d4466;
  --text3: #7a7a9a;
  --name-color: #1a1a2e;
  --tag-bg: rgba(139,105,20,0.1);
  --tag-border: rgba(139,105,20,0.3);
  --bar-bg: #e0d8cb;
  --shadow: 0 4px 24px rgba(0,0,0,0.1);
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.07);
}

/* ─── RESET ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 15px; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  transition: background 0.35s, color 0.35s;
  line-height: 1.6;
}

/* ─── TOP BAR ─── */
#topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  padding: 10px 24px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(10px);
  box-shadow: var(--shadow-sm);
  flex-wrap: wrap;
}
.topbar-left, .topbar-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.topbar-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.03em;
  margin-right: 10px;
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 14px;
  border-radius: 30px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text2);
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.btn:hover { border-color: var(--accent); color: var(--accent); }
.btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #0d1117;
  font-weight: 600;
}
.btn-icon {
  padding: 6px 12px;
}

/* ─── MAIN WRAPPER ─── */
#cv {
  max-width: 1060px;
  margin: 0 auto;
  padding: 32px 20px 60px;
  animation: fadeIn 0.6s ease both;
}
@keyframes fadeIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }

/* ─── HERO ─── */
.hero {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 28px;
  align-items: center;
  padding: 36px 40px 30px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
}
.hero-avatar {
  width: 110px;
  height: 110px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--accent);
  box-shadow: 0 0 0 6px var(--accent-soft), var(--shadow-sm);
  flex-shrink: 0;
  display: block;
  transition: border-color 0.3s;
}
.hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 80% 0%, var(--accent-soft) 0%, transparent 60%);
  pointer-events: none;
}
.hero-name {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 700;
  color: var(--name-color);
  line-height: 1.1;
  letter-spacing: -0.01em;
  margin-bottom: 8px;
}
.hero-title {
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--accent);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.hero-contact {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.contact-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  background: var(--accent-soft);
  border: 1px solid var(--tag-border);
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--text2);
  text-decoration: none;
  transition: all 0.2s;
}
.contact-item:hover { color: var(--accent); border-color: var(--accent); }
.contact-item .icon { font-size: 0.85rem; }
.hero-tags {
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: flex-end;
}
.hero-tag {
  padding: 5px 14px;
  background: var(--tag-bg);
  border: 1px solid var(--tag-border);
  border-radius: 20px;
  font-size: 0.73rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ─── GRID LAYOUT ─── */
.cv-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 22px;
  align-items: start;
}

/* ─── SECTION ─── */
.section {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 28px;
  margin-bottom: 22px;
  transition: border-color 0.2s;
}
.section:hover { border-color: rgba(201,168,76,0.3); }
.section-title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
  letter-spacing: 0.02em;
}
.section-title .hex { font-size: 1rem; opacity: 0.7; }

/* ─── ABOUT ─── */
.about-text {
  font-size: 0.88rem;
  color: var(--text2);
  line-height: 1.75;
}

/* ─── EXPERIENCE ─── */
.exp-item {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 14px;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}
.exp-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
.exp-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent);
  margin-top: 5px;
  flex-shrink: 0;
  box-shadow: 0 0 0 3px var(--accent-soft);
}
.exp-role {
  font-weight: 600;
  font-size: 0.92rem;
  color: var(--text);
  margin-bottom: 2px;
}
.exp-company {
  font-size: 0.82rem;
  color: var(--accent);
  font-weight: 500;
  margin-bottom: 4px;
}
.exp-desc {
  font-size: 0.8rem;
  color: var(--text3);
  margin-bottom: 4px;
}
.exp-year {
  font-size: 0.73rem;
  font-weight: 600;
  color: var(--text3);
  letter-spacing: 0.04em;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 8px;
  display: inline-block;
}

/* ─── SKILL BARS ─── */
.skill-bar-item {
  margin-bottom: 14px;
}
.skill-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 5px;
}
.skill-bar-name { font-size: 0.82rem; font-weight: 500; color: var(--text2); }
.skill-bar-pct { font-size: 0.78rem; color: var(--accent); font-weight: 600; }
.skill-bar-track {
  height: 5px;
  background: var(--bar-bg);
  border-radius: 3px;
  overflow: hidden;
}
.skill-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 3px;
  width: 0;
  transition: width 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* ─── SOFT SKILLS ─── */
.soft-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.soft-tag {
  padding: 5px 13px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--text2);
  font-weight: 400;
}

/* ─── EDUCATION ─── */
.edu-item {
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}
.edu-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
.edu-title { font-size: 0.88rem; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.edu-sub { font-size: 0.78rem; color: var(--text2); margin-bottom: 4px; }
.edu-badge {
  display: inline-block;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  padding: 2px 8px;
  border-radius: 4px;
  text-transform: uppercase;
}
.badge-progress { background: rgb(253, 217, 116); color: #f72804; border: 1px solid rgba(255, 175, 2, 0.842); }
.badge-unfinished { background: rgba(235, 96, 228, 0.13); color: #e624c5; border: 1px solid rgba(102, 14, 216, 0.719); }
.badge-done { background: rgba(145, 245, 165, 0.87); color: #024913; border: 1px solid rgba(9, 252, 57, 0.918); }

/* ─── CERTS ─── */
.cert-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 14px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border);
}
.cert-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
.cert-num {
  width: 26px; height: 26px;
  border-radius: 50%;
  background: var(--accent);
  color: #0d1117;
  font-size: 0.72rem;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.cert-name { font-size: 0.83rem; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.cert-org { font-size: 0.75rem; color: var(--text2); margin-bottom: 3px; }
.cert-hours {
  font-size: 0.7rem; font-weight: 700; color: var(--accent);
  background: var(--accent-soft);
  padding: 1px 8px; border-radius: 4px; display: inline-block;
}

/* ─── TOOLS ─── */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.tool-chip {
  padding: 5px 13px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  font-size: 0.77rem;
  font-weight: 500;
  color: var(--text2);
  transition: all 0.2s;
}
.tool-chip:hover { border-color: var(--accent); color: var(--accent); }

/* ─── LANGUAGES ─── */
.lang-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.lang-item:last-child { border-bottom: none; }
.lang-name { font-size: 0.85rem; font-weight: 500; }
.lang-level {
  font-size: 0.75rem;
  color: var(--text2);
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 2px 9px;
}

/* ─── RESOURCES ─── */
.resource-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  text-decoration: none;
  color: var(--text2);
  font-size: 0.82rem;
  font-weight: 500;
  margin-bottom: 8px;
  transition: all 0.2s;
}
.resource-link:last-child { margin-bottom: 0; }
.resource-link:hover { border-color: var(--accent); color: var(--accent); }
.resource-icon { font-size: 1.1rem; }

/* ─── PROFILE BOX ─── */
.profile-text {
  font-size: 0.84rem;
  color: var(--text2);
  line-height: 1.7;
}
.profile-list {
  margin-top: 10px;
  padding-left: 0;
  list-style: none;
}
.profile-list li {
  padding: 4px 0;
  font-size: 0.82rem;
  color: var(--text2);
  display: flex;
  align-items: flex-start;
  gap: 8px;
}
.profile-list li::before {
  content: '◆';
  color: var(--accent);
  font-size: 0.55rem;
  margin-top: 5px;
  flex-shrink: 0;
}

/* ─── DIGITAL SECTION ─── */
.digital-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.digital-card {
  padding: 12px 14px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
}
.digital-card-icon { font-size: 1.1rem; margin-bottom: 4px; }
.digital-card-title { font-size: 0.8rem; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.digital-card-desc { font-size: 0.73rem; color: var(--text3); line-height: 1.5; }

/* ─── FOOTER ─── */
.cv-footer {
  text-align: center;
  padding: 20px;
  color: var(--text3);
  font-size: 0.75rem;
  letter-spacing: 0.04em;
}

/* ─── RESPONSIVE ─── */
@media (max-width: 800px) {
  .cv-grid { grid-template-columns: 1fr; }
  .hero { grid-template-columns: 1fr; text-align: center; }
  .hero-avatar { margin: 0 auto; }
  .hero-contact { justify-content: center; }
  .hero-tags { flex-direction: row; align-items: center; justify-content: center; flex-wrap: wrap; }
  .section { padding: 20px; }
  .digital-grid { grid-template-columns: 1fr; }
}
@media (max-width: 500px) {
  #topbar { padding: 8px 12px; }
  #cv { padding: 16px 12px 40px; }
  .hero { padding: 22px 18px; }
  .hero-name { font-size: 1.7rem; }
}

/* ─── PRINT ─── */
@media print {
  #topbar { display: none !important; }
  body { background: #fff !important; color: #000 !important; }
  .hero, .section {
    background: #fff !important;
    border: 1px solid #ccc !important;
    break-inside: avoid;
    box-shadow: none !important;
  }
  :root {
    --bg: #fff; --bg2: #fff; --bg3: #f8f8f8;
    --text: #111; --text2: #333; --text3: #666;
    --accent: #8b6914; --accent2: #a07820;
    --border: #ddd;
    --bar-bg: #e0e0e0;
    --shadow: none;
    --tag-bg: #f0e8d0;
    --tag-border: #c9a84c;
    --name-color: #111;
  }
  #cv { max-width: 100%; padding: 10px; }
  .cv-grid { grid-template-columns: 1fr 280px; }
  .section { margin-bottom: 14px; padding: 16px; }
  a { color: inherit; text-decoration: none; }
}
</style>
</head>
